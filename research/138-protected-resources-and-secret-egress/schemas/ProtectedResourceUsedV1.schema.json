{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.dev/schemas/protected-resource-used/v1",
  "title": "ProtectedResourceUsedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "eventType",
    "occurredAt",
    "spaceId",
    "resourceId",
    "secretRef",
    "grantId",
    "purpose",
    "tool",
    "trustedBoundary",
    "renderMode",
    "resultStatus",
    "emittedFields",
    "fingerprint"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "eventId": {
      "type": "string",
      "pattern": "^prevt_[a-z0-9][a-z0-9_-]{8,120}$"
    },
    "eventType": {
      "const": "ProtectedResourceUsedV1"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "spaceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "resourceId": {
      "type": "string",
      "pattern": "^pr_[a-z0-9][a-z0-9_-]{6,96}$"
    },
    "secretRef": {
      "type": "string",
      "pattern": "^secretref_[a-z0-9][a-z0-9_-]{8,120}$"
    },
    "grantId": {
      "type": "string",
      "pattern": "^grant_[a-z0-9][a-z0-9_-]{8,120}$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "tool": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "trustedBoundary": {
      "type": "string",
      "enum": [
        "cortex_provider_transport",
        "cortex_sealed_renderer",
        "cortex_redacted_inspector",
        "external_secret_manager"
      ]
    },
    "renderMode": {
      "type": "string",
      "enum": [
        "status_only",
        "fingerprint",
        "redacted_preview",
        "sealed_output"
      ]
    },
    "resultStatus": {
      "type": "string",
      "enum": [
        "success",
        "denied",
        "expired",
        "revoked",
        "boundary_error"
      ]
    },
    "emittedFields": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "status",
          "fingerprint",
          "redacted_preview",
          "sealed_artifact_ref",
          "audit_ref"
        ]
      },
      "uniqueItems": true
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{12,64}$"
    },
    "redactedPreview": {
      "type": "string",
      "maxLength": 2000
    },
    "sealedArtifactRef": {
      "type": "string",
      "maxLength": 240
    }
  }
}
