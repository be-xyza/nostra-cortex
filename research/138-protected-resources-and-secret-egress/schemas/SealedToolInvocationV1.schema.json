{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.dev/schemas/sealed-tool-invocation/v1",
  "title": "SealedToolInvocationV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "invocationId",
    "tool",
    "spaceId",
    "purpose",
    "grantId",
    "secretRefs",
    "inputMode",
    "requestedRenderMode",
    "requestedBy",
    "requestedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "invocationId": {
      "type": "string",
      "pattern": "^sealedinv_[a-z0-9][a-z0-9_-]{8,120}$"
    },
    "tool": {
      "type": "string",
      "enum": [
        "sealed_provider_invoke",
        "sealed_document_render",
        "redacted_config_inspect"
      ]
    },
    "spaceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "grantId": {
      "type": "string",
      "pattern": "^grant_[a-z0-9][a-z0-9_-]{8,120}$"
    },
    "secretRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^secretref_[a-z0-9][a-z0-9_-]{8,120}$"
      }
    },
    "inputMode": {
      "type": "string",
      "enum": [
        "agent_request",
        "operator_request",
        "workflow_adapter"
      ]
    },
    "requestedRenderMode": {
      "type": "string",
      "enum": [
        "status_only",
        "fingerprint",
        "redacted_preview",
        "sealed_output"
      ]
    },
    "requestedBy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
