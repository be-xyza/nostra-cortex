{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.dev/schemas/secret-ref/v1",
  "title": "SecretRefV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "secretRef",
    "resourceId",
    "kind",
    "spaceId",
    "fingerprint",
    "renderMode",
    "expiresAt",
    "issuedAt",
    "issuedBy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "secretRef": {
      "type": "string",
      "pattern": "^secretref_[a-z0-9][a-z0-9_-]{8,120}$"
    },
    "resourceId": {
      "type": "string",
      "pattern": "^pr_[a-z0-9][a-z0-9_-]{6,96}$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "provider_key",
        "credential",
        "pii_field",
        "sealed_document",
        "identity_claim"
      ]
    },
    "spaceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{12,64}$"
    },
    "renderMode": {
      "type": "string",
      "enum": [
        "status_only",
        "fingerprint",
        "redacted_preview",
        "sealed_output"
      ]
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "issuedBy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    }
  }
}
