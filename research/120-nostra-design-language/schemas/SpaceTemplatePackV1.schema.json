{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.local/schemas/space-template-pack-v1.schema.json",
  "title": "SpaceTemplatePackV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "template_pack_id",
    "authority_mode",
    "space_archetype",
    "profile_defaults_ref",
    "allowed_surface_scope",
    "included_import_refs",
    "promotion_gate"
  ],
  "properties": {
    "schema_version": {
      "const": "SpaceTemplatePackV1"
    },
    "template_pack_id": {
      "type": "string",
      "pattern": "^space-template-pack:[a-z0-9][a-z0-9._:-]*$"
    },
    "authority_mode": {
      "const": "recommendation_only"
    },
    "space_archetype": {
      "enum": [
        "research_observatory",
        "community_lab",
        "project_delivery",
        "governance_forum",
        "personal_studio"
      ]
    },
    "profile_defaults_ref": {
      "type": "string",
      "minLength": 1
    },
    "allowed_surface_scope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "space_shell",
          "workbench",
          "artifact_viewer",
          "proposal_preview",
          "execution_surface",
          "hybrid_surface"
        ]
      }
    },
    "included_import_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "promotion_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_recommendation",
        "required_checks"
      ],
      "properties": {
        "required_recommendation": {
          "enum": [
            "adopt",
            "adapt",
            "needs_steward_review"
          ]
        },
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "locked_reality_snapshot",
              "space_design_profile",
              "design_element_imports",
              "brand_policy",
              "accessibility",
              "a2ui_theme_policy",
              "space_capability_alignment",
              "hermes_advisory_only"
            ]
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
