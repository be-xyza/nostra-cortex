{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.local/schemas/design-audit-unit-v1.schema.json",
  "title": "DesignAuditUnitV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_unit_id",
    "authority_mode",
    "target",
    "reality_snapshot_ref",
    "inputs",
    "expected_output"
  ],
  "properties": {
    "schema_version": {
      "const": "DesignAuditUnitV1"
    },
    "audit_unit_id": {
      "type": "string",
      "pattern": "^design-audit:[a-z0-9][a-z0-9._:-]*$"
    },
    "authority_mode": {
      "const": "recommendation_only"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "enum": [
            "space_design_profile",
            "design_element_import",
            "space_template_pack"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reality_snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "input_id",
          "path",
          "authority_tier"
        ],
        "properties": {
          "input_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "authority_tier": {
            "enum": [
              "locked_truth",
              "candidate",
              "reference",
              "operator_observation"
            ]
          }
        }
      }
    },
    "expected_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "allowed_decisions"
      ],
      "properties": {
        "format": {
          "const": "DesignRecommendationV1"
        },
        "allowed_decisions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "adopt",
              "adapt",
              "reject",
              "needs_steward_review"
            ]
          }
        }
      }
    }
  }
}
