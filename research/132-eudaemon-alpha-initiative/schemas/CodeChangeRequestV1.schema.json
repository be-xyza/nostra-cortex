{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.local/schemas/CodeChangeRequestV1.schema.json",
  "title": "CodeChangeRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "codeChangeRequestId",
    "dispatchDecisionRef",
    "taskRef",
    "mode",
    "authorityLevel",
    "riskLevel",
    "scope",
    "requiredChecks",
    "forbiddenActions",
    "expectedOutputs",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "codeChangeRequestId": { "type": "string", "minLength": 3 },
    "dispatchDecisionRef": { "type": "string", "minLength": 3 },
    "taskRef": { "type": "string", "minLength": 3 },
    "mode": {
      "type": "string",
      "enum": ["patch_prep", "isolated_patch_candidate", "commit_candidate", "pr_candidate", "deploy_candidate"]
    },
    "authorityLevel": {
      "type": "string",
      "enum": ["D1", "D2", "D3", "D4", "D5"]
    },
    "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "structural"] },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedPaths"],
      "properties": {
        "allowedPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string" }
      }
    },
    "requiredChecks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "forbiddenActions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "expectedOutputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["handoff", "patch", "changed_files", "verification_results", "risk_note", "review_prompt"]
      },
      "uniqueItems": true
    },
    "worktreePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "branchPrefix": { "type": "string" }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
