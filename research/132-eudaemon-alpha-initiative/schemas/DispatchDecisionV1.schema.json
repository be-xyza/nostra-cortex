{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.local/schemas/DispatchDecisionV1.schema.json",
  "title": "DispatchDecisionV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "decisionId",
    "requestId",
    "decision",
    "approvedLevel",
    "decider",
    "decidedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "decisionId": { "type": "string", "minLength": 3 },
    "requestId": { "type": "string", "minLength": 3 },
    "decision": {
      "type": "string",
      "enum": ["approve", "reject", "revise", "escalate", "pause"]
    },
    "approvedLevel": {
      "type": "string",
      "enum": ["D0", "D1", "D2", "D3", "D4", "D5"]
    },
    "decider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "enum": ["human", "steward", "operator"] },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "rationale": { "type": "string" },
    "conditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "decidedAt": { "type": "string", "format": "date-time" },
    "transportReceiptRef": { "type": "string" }
  }
}
