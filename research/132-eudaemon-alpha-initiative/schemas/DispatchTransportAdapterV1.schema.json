{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.local/schemas/DispatchTransportAdapterV1.schema.json",
  "title": "DispatchTransportAdapterV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "adapterId",
    "transportKind",
    "mode",
    "supportedOperations",
    "authority"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "adapterId": { "type": "string", "minLength": 3 },
    "transportKind": {
      "type": "string",
      "enum": ["hermes_gateway", "telegram", "cortex_web", "cli", "matrix", "email", "webhook", "other"]
    },
    "mode": { "type": "string", "enum": ["dry_run", "live"] },
    "supportedOperations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["read_outbox", "send_envelope", "record_receipt", "ingest_reply", "emit_dispatch_decision", "apply_decision"]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxLevel", "mutationAllowed", "requiresMatchingRequest"],
      "properties": {
        "maxLevel": { "type": "string", "enum": ["D0", "D1", "D2", "D3", "D4", "D5"] },
        "mutationAllowed": { "type": "boolean" },
        "requiresMatchingRequest": { "type": "boolean" }
      }
    },
    "notes": { "type": "string" }
  }
}
