{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.local/schemas/AgentProfileV1.schema.json",
  "title": "AgentProfileV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "registryId", "authorityMode", "generatedAt", "profiles"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "registryId": { "type": "string", "minLength": 3 },
    "authorityMode": { "const": "recommendation_only" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/profile" }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agentId",
        "harnessId",
        "spaceBinding",
        "purpose",
        "authority",
        "allowedOutputs",
        "forbiddenActions",
        "transportBindings",
        "runtimeBoundary",
        "memoryPolicy",
        "healthStatus",
        "lifecycleState"
      ],
      "properties": {
        "agentId": { "type": "string", "minLength": 3 },
        "harnessId": { "type": "string", "minLength": 3 },
        "spaceBinding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": { "type": "string", "enum": ["none", "single_space", "multi_space", "operator_only"] },
            "spaceId": { "type": "string" },
            "roleOrArchetype": { "type": "string" }
          }
        },
        "purpose": { "type": "string", "minLength": 3 },
        "authority": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxDispatchLevel", "sourceMutationAllowed", "runtimeMutationAllowed"],
          "properties": {
            "maxDispatchLevel": { "type": "string", "enum": ["D0", "D1", "D2", "D3", "D4", "D5"] },
            "sourceMutationAllowed": { "type": "boolean" },
            "runtimeMutationAllowed": { "type": "boolean" }
          }
        },
        "allowedOutputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "forbiddenActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["source_mutation", "runtime_mutation", "commit", "push", "pull_request", "deploy", "canister_call", "graph_mutation", "provider_topology_exposure", "authority_escalation"]
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "transportBindings": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        },
        "runtimeBoundary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "rationale"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["checked", "not_inspectable", "planned", "blocked"]
            },
            "boundaryRef": { "type": "string" },
            "rationale": { "type": "string", "minLength": 3 }
          }
        },
        "memoryPolicy": { "type": "string", "minLength": 3 },
        "healthStatus": { "type": "string", "enum": ["unknown", "healthy", "blocked", "degraded", "restricted"] },
        "lifecycleState": { "type": "string", "enum": ["proposed", "sandboxed", "pilot", "active", "restricted", "deprecated", "retired"] }
      }
    }
  }
}
