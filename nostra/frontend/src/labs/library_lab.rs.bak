use dioxus::prelude::*;
use serde::{Deserialize, Serialize};

#[derive(Props, Clone, PartialEq)]
pub struct LibraryLabProps {
    pub on_back: EventHandler<()>,
}

#[derive(Clone, Debug, PartialEq)]
enum LibraryView {
    Bookshelf,
    Reader(String), // Book ID
}

#[derive(Clone, Debug, Serialize, Deserialize)]
struct Book {
    #[serde(rename = "@context")]
    pub context: serde_json::Value,
    pub meta: BookMeta,
    #[serde(skip)]
    pub cover_color: String,
    pub content: Vec<BookContent>,
    #[serde(default)]
    pub knowledge_graph: Option<KnowledgeGraph>,
}

#[derive(Clone, Debug, Serialize, Deserialize)]
struct BookMeta {
    pub id: String,
    pub title: String,
    pub version: Option<String>,
    pub phase: Option<String>,
    pub provenance: Provenance,
}

#[derive(Clone, Debug, Serialize, Deserialize)]
struct Provenance {
    pub author_did: String,
    pub space_did: String,
    pub created_at: String,
}

#[derive(Clone, Debug, Serialize, Deserialize)]
struct BookContent {
    pub id: String,
    pub title: Option<String>,
    #[serde(rename = "type")]
    pub content_type: String,
    pub blocks: Vec<Block>,
}

#[derive(Clone, Debug, Serialize, Deserialize)]
#[serde(tag = "type")]
enum Block {
    #[serde(rename = "Block::Heading")]
    Heading { level: u8, content: String },
    #[serde(rename = "Block::Paragraph")]
    Paragraph { content: ContentValue },
    #[serde(rename = "Block::Reference")]
    Reference {
        ref_id: String,
        display_text: String,
    },
    #[serde(untagged)]
    LegacyHtml { content: String },
}

#[derive(Clone, Debug, Serialize, Deserialize)]
#[serde(untagged)]
enum ContentValue {
    String(String),
    Rich(Vec<RichTextSpan>),
}

#[derive(Clone, Debug, Serialize, Deserialize)]
#[serde(tag = "type")]
enum RichTextSpan {
    Text { value: String },
    Bold { value: String },
    Italic { value: String },
}

#[derive(Clone, Debug, Serialize, Deserialize)]
struct KnowledgeGraph {
    pub entities: Vec<Entity>,
    pub relations: Vec<Relation>,
}

#[derive(Clone, Debug, Serialize, Deserialize)]
struct Entity {
    pub id: String,
    #[serde(rename = "type")]
    pub entity_type: String,
    pub properties: std::collections::HashMap<String, String>,
}

#[derive(Clone, Debug, Serialize, Deserialize)]
struct Relation {
    pub subject: String,
    pub predicate: String,
    pub object: String,
}

#[derive(Clone, Debug, PartialEq)]
struct BookCollection {
    id: CollectionId,
    name: String,
    description: String,
    icon: String,
    book_ids: Vec<String>,
    color_theme: String,
}

#[derive(Clone, Debug, PartialEq, Eq, Hash)]
enum CollectionId {
    /// The Nine Constitutional Documents - all core governance
    Constitutional,
    /// Culture & Philosophy: Labs Constitution, UI/UX Manifesto
    Culture,
    /// Structure & Roles: Spaces, Stewardship, Contribution Lifecycle
    Structure,
    /// Authority & Process: Agent Charter, Governance Escalation
    Authority,
    /// Knowledge & Security: Knowledge Integrity, Security Privacy
    Security,
    /// Regulatory Compliance: GDPR, HIPAA, SOC2
    Compliance,
    /// System/Legacy: Internal docs, system references
    System,
    /// User Favorites
    Favorites,
    /// User Reading List
    ReadingList,
}

impl ToString for CollectionId {
    fn to_string(&self) -> String {
        match self {
            CollectionId::Constitutional => "Constitutional".to_string(),
            CollectionId::Culture => "Culture".to_string(),
            CollectionId::Structure => "Structure".to_string(),
            CollectionId::Authority => "Authority".to_string(),
            CollectionId::Security => "Security".to_string(),
            CollectionId::Compliance => "Compliance".to_string(),
            CollectionId::System => "System".to_string(),
            CollectionId::Favorites => "Favorites".to_string(),
            CollectionId::ReadingList => "Reading List".to_string(),
        }
    }
}

#[derive(Clone, Debug, PartialEq, Serialize, Deserialize)]
struct LabConfig {
    pub sync_target: SyncTarget,
    pub encryption: EncryptionLevel,
    pub human_in_loop: bool,
    pub telemetry_enabled: bool,
    pub agent_access: AgentAccessLevel,
}

impl Default for LabConfig {
    fn default() -> Self {
        Self {
            sync_target: SyncTarget::Local,
            encryption: EncryptionLevel::Standard,
            human_in_loop: true,
            telemetry_enabled: true,
            agent_access: AgentAccessLevel::ReadOnly,
        }
    }
}

#[derive(Clone, Debug, PartialEq, Serialize, Deserialize)]
enum SyncTarget {
    Local,
    Canister,
}

impl ToString for SyncTarget {
    fn to_string(&self) -> String {
        match self {
            SyncTarget::Local => "Local Only".to_string(),
            SyncTarget::Canister => "Canister Sync".to_string(),
        }
    }
}

#[derive(Clone, Debug, PartialEq, Serialize, Deserialize)]
enum EncryptionLevel {
    Standard,
    High,
}

impl ToString for EncryptionLevel {
    fn to_string(&self) -> String {
        match self {
            EncryptionLevel::Standard => "Standard (AES-256)".to_string(),
            EncryptionLevel::High => "High (Post-Quantum)".to_string(),
        }
    }
}

#[derive(Clone, Debug, PartialEq, Serialize, Deserialize)]
enum AgentAccessLevel {
    ReadOnly,
    ReadWrite,
}

impl ToString for AgentAccessLevel {
    fn to_string(&self) -> String {
        match self {
            AgentAccessLevel::ReadOnly => "Read Only".to_string(),
            AgentAccessLevel::ReadWrite => "Read & Write".to_string(),
        }
    }
}

#[component]
pub fn LibraryLab(props: LibraryLabProps) -> Element {
    let mut current_view = use_signal(|| LibraryView::Bookshelf);
    let mut show_raw = use_signal(|| false);
    let mut show_cortex = use_signal(|| false);
    let mut show_config = use_signal(|| false);
    let mut config = use_signal(|| LabConfig::default());

    // Favorites & Reading List Signals (Persisted in LocalStorage in real app)
    let mut favorites = use_signal(|| std::collections::HashSet::<String>::new());
    let mut reading_list = use_signal(|| std::collections::HashSet::<String>::new());

    // Pre-calculate reader controls classes
    let btn_class = format!(
        "w-10 h-6 rounded-full transition-colors flex items-center px-1 {}",
        if *show_raw.read() {
            "bg-primary"
        } else {
            "bg-muted"
        }
    );
    let knob_class = format!(
        "w-4 h-4 rounded-full bg-white transition-transform {}",
        if *show_raw.read() {
            "translate-x-4"
        } else {
            "translate-x-0"
        }
    );

    let cortex_btn_class = format!(
        "w-10 h-6 rounded-full transition-colors flex items-center px-1 {}",
        if *show_cortex.read() {
            "bg-purple-600"
        } else {
            "bg-muted"
        }
    );
    let cortex_knob_class = format!(
        "w-4 h-4 rounded-full bg-white transition-transform {}",
        if *show_cortex.read() {
            "translate-x-4"
        } else {
            "translate-x-0"
        }
    );

    // Load books from embedded JSON files
    fn load_books() -> Vec<Book> {
        // The Nine Constitutional Documents of Nostra
        const LABS_CONSTITUTION_JSON: &str =
            include_str!("../../../../research/034-nostra-labs/books/labs_constitution.json");
        const UI_UX_MANIFESTO_JSON: &str =
            include_str!("../../../../research/034-nostra-labs/books/ui_ux_manifesto.json");
        const CONTRIBUTION_LIFECYCLE_JSON: &str = include_str!(
            "../../../../research/034-nostra-labs/books/contribution_lifecycle_constitution.json"
        );
        const STEWARDSHIP_ROLES_JSON: &str = include_str!(
            "../../../../research/034-nostra-labs/books/stewardship_roles_constitution.json"
        );
        const AGENT_CHARTER_JSON: &str =
            include_str!("../../../../research/034-nostra-labs/books/agent_charter.json");
        const SPACES_CONSTITUTION_JSON: &str =
            include_str!("../../../../research/034-nostra-labs/books/spaces_constitution.json");
        const GOVERNANCE_ESCALATION_JSON: &str = include_str!(
            "../../../../research/034-nostra-labs/books/governance_escalation_framework.json"
        );
        const KNOWLEDGE_INTEGRITY_JSON: &str = include_str!(
            "../../../../research/034-nostra-labs/books/knowledge_integrity_doctrine.json"
        );
        const SECURITY_PRIVACY_JSON: &str = include_str!(
            "../../../../research/034-nostra-labs/books/security_privacy_doctrine.json"
        );

        // NEW: Full Book Spec
        const FULL_BOOK_SPEC_JSON: &str =
            include_str!("../../../../research/057-development-brain/SPECS/FULL_BOOK_SCHEMA.json");

        let mut books = Vec::new();

        // Helper to convert Legacy JSON -> V2 Book Struct
        let convert_legacy = |json: &str, color: &str| -> Option<Book> {
            #[derive(Deserialize)]
            struct LegacyBook {
                id: String,
                title: String,
                author: String,
                description: String,
                chapters: Vec<LegacyChapter>,
                version: Option<String>,
                published: Option<String>,
            }
            #[derive(Deserialize)]
            struct LegacyChapter {
                title: String,
                content: String,
            }

            if let Ok(legacy) = serde_json::from_str::<LegacyBook>(json) {
                Some(Book {
                    context: serde_json::Value::Null,
                    meta: BookMeta {
                        id: legacy.id,
                        title: legacy.title.clone(),
                        version: legacy.version,
                        phase: Some("Archival".to_string()),
                        provenance: Provenance {
                            author_did: legacy.author,
                            space_did: "did:nostra:space:legacy".to_string(),
                            created_at: legacy.published.unwrap_or_default(),
                        },
                    },
                    cover_color: color.to_string(),
                    content: legacy
                        .chapters
                        .into_iter()
                        .enumerate()
                        .map(|(i, ch)| BookContent {
                            id: format!("ch{}", i),
                            title: Some(ch.title.clone()),
                            content_type: "Contribution::Chapter".to_string(),
                            blocks: vec![
                                Block::Heading {
                                    level: 2,
                                    content: ch.title,
                                },
                                Block::LegacyHtml {
                                    content: ch.content,
                                },
                            ],
                        })
                        .collect(),
                    knowledge_graph: None,
                })
            } else {
                None
            }
        };

        // Load Legacy Constitutional Documents
        if let Some(b) = convert_legacy(LABS_CONSTITUTION_JSON, "bg-purple-600") {
            books.push(b);
        }
        if let Some(b) = convert_legacy(UI_UX_MANIFESTO_JSON, "bg-indigo-600") {
            books.push(b);
        }
        if let Some(b) = convert_legacy(CONTRIBUTION_LIFECYCLE_JSON, "bg-emerald-600") {
            books.push(b);
        }
        if let Some(b) = convert_legacy(STEWARDSHIP_ROLES_JSON, "bg-amber-600") {
            books.push(b);
        }
        if let Some(b) = convert_legacy(AGENT_CHARTER_JSON, "bg-cyan-600") {
            books.push(b);
        }
        if let Some(b) = convert_legacy(SPACES_CONSTITUTION_JSON, "bg-teal-600") {
            books.push(b);
        }
        if let Some(b) = convert_legacy(GOVERNANCE_ESCALATION_JSON, "bg-blue-600") {
            books.push(b);
        }
        if let Some(b) = convert_legacy(KNOWLEDGE_INTEGRITY_JSON, "bg-violet-600") {
            books.push(b);
        }
        if let Some(b) = convert_legacy(SECURITY_PRIVACY_JSON, "bg-rose-600") {
            books.push(b);
        }

        // Load V2 Full Spec
        if let Ok(mut v2_book) = serde_json::from_str::<Book>(FULL_BOOK_SPEC_JSON) {
            v2_book.cover_color = "bg-orange-600".to_string(); // Highlight the test specimen
            // Hack to ensure title is displayed on cover if missing from meta or needs override
            // (The struct definitions map effectively)
            books.push(v2_book);
        } else {
            println!("Failed to parse FULL_BOOK_SPEC_JSON");
        }

        books
    }

    // Load constitutional books from JSON + add GDPR mock + Legacy Mockup
    let mut books = load_books();

    // GDPR Mock
    books.push(Book {
        context: serde_json::Value::Null,
        meta: BookMeta {
            id: "book_gdpr".to_string(),
            title: "The Nostra GDPR Standard".to_string(),
            version: Some("0.1".to_string()),
            phase: Some("Deliberative".to_string()),
            provenance: Provenance {
                author_did: "Nostra Governance".to_string(),
                space_did: "did:nostra:space:compliance".to_string(),
                created_at: "2026-01-22".to_string(),
            },
        },
        cover_color: "bg-blue-600".to_string(),
        content: vec![
                BookContent {
                    id: "ch1".to_string(),
                    title: Some("Chapter 1: General Provisions".to_string()),
                    content_type: "Contribution::Chapter".to_string(),
                    blocks: vec![
                        Block::LegacyHtml { content: r#"
                        <h2>Article 1: Subject-matter and objectives</h2>
                        <p>1. This Regulation lays down rules relating to the protection of natural persons with regard to the processing of personal data and rules relating to the free movement of personal data.</p>
                        <p>2. This Regulation protects fundamental rights and freedoms of natural persons and in particular their right to the protection of personal data.</p>
                        <h2>Article 4: Definitions</h2>
                        <p>For the purposes of this Regulation:</p>
                        <ul>
                            <li>(1) ‘personal data’ means any information relating to an identified or identifiable natural person (‘data subject’);</li>
                            <li>(2) ‘processing’ means any operation or set of operations which is performed on personal data...</li>
                        </ul>
                    "#.to_string() }
                    ],
                },
                BookContent {
                    id: "ch3".to_string(),
                    title: Some("Chapter 3: Rights of the Data Subject".to_string()),
                    content_type: "Contribution::Chapter".to_string(),
                    blocks: vec![
                        Block::LegacyHtml { content: r#"
                        <h2>Article 17: Right to Erasure ('Right to be Forgotten')</h2>
                        <p>1. The data subject shall have the right to obtain from the controller the erasure of personal data concerning him or her without undue delay...</p>
                        <PolicyBlock id='art_17' intent='erasure' />
                        <hr />
                        <h2>Article 20: Right to Data Portability</h2>
                        <p>1. The data subject shall have the right to receive the personal data concerning him or her, which he or she has provided to a controller...</p>
                        <PolicyBlock id='art_20' intent='portability' />
                    "#.to_string() }
                    ],
                },
                BookContent {
                    id: "ch4".to_string(),
                    title: Some("Chapter 4: Controller and Processor".to_string()),
                    content_type: "Contribution::Chapter".to_string(),
                    blocks: vec![
                        Block::LegacyHtml { content: r#"
                        <h2>Article 30: Records of processing activities</h2>
                        <p>1. Each controller and, where applicable, the controller's representative, shall maintain a record of processing activities under its responsibility.</p>
                        <PolicyBlock id='art_30' intent='audit' />
                    "#.to_string() }
                    ],
                },
        ],
        knowledge_graph: None,
    });

    // Legacy Mockup Import
    const LEGACY_MOCKUP_MD: &str = include_str!(
        "../../../../research/034-nostra-labs/_archive/MOCKUP_LABS_PLAYGROUND_2026-01-19_Initial.md"
    );
    let legacy_mockup_json = serde_json::to_string(&serde_json::json!({
            "id": "legacy_mockup",
            "title": "Legacy Labs Playground Mockup",
            "author": "Nostra Design Team",
            "version": "2026-01-19",
            "published": "2026-01-19",
            "description": "Original mockup for the Labs Playground transformation. Preserved for historical lineage.",
            "chapters": [
                {
                    "title": "Mockup Content",
                    "content": format!("<pre>{}</pre>", LEGACY_MOCKUP_MD)
                }
            ]
        })).unwrap();

    if let Some(b) = convert_legacy(&legacy_mockup_json, "bg-gray-700") {
        books.push(b);
    }

    // Create Collections - organized by Nostra's nine constitutional pillars
    let create_collections = |_books: &Vec<Book>| -> Vec<BookCollection> {
        let mut collections = Vec::new();

        // 1. ALL Constitutional Documents (The Complete Nine)
        let all_constitutional_ids = vec![
            "urn:nostra:book:labs-constitution".to_string(),
            "urn:nostra:book:ui-ux-manifesto".to_string(),
            "urn:nostra:book:contribution-lifecycle".to_string(),
            "urn:nostra:book:stewardship-roles".to_string(),
            "urn:nostra:book:agent-charter".to_string(),
            "urn:nostra:book:spaces-constitution".to_string(),
            "urn:nostra:book:governance-escalation".to_string(),
            "urn:nostra:book:knowledge-integrity".to_string(),
            "urn:nostra:book:security-privacy".to_string(),
        ];
        collections.push(BookCollection {
            id: CollectionId::Constitutional,
            name: "Constitutional Documents".to_string(),
            description: "The Nine foundational constitutions governing Nostra's culture, knowledge, structure, authority, process, agents, security, governance, and design.".to_string(),
            icon: "⚖️".to_string(),
            book_ids: all_constitutional_ids,
            color_theme: "bg-purple-600".to_string(),
        });

        // 2. Culture & Philosophy
        let culture_ids = vec![
            "urn:nostra:book:labs-constitution".to_string(),
            "urn:nostra:book:ui-ux-manifesto".to_string(),
        ];
        collections.push(BookCollection {
            id: CollectionId::Culture,
            name: "Culture & Philosophy".to_string(),
            description: "Core values, experimental philosophy, and design principles.".to_string(),
            icon: "🎨".to_string(),
            book_ids: culture_ids,
            color_theme: "bg-purple-600".to_string(),
        });

        // 3. Structure & Roles
        let structure_ids = vec![
            "urn:nostra:book:spaces-constitution".to_string(),
            "urn:nostra:book:stewardship-roles".to_string(),
            "urn:nostra:book:contribution-lifecycle".to_string(),
        ];
        collections.push(BookCollection {
            id: CollectionId::Structure,
            name: "Structure & Roles".to_string(),
            description: "Spaces, stewardship responsibilities, and contribution workflows."
                .to_string(),
            icon: "🏛️".to_string(),
            book_ids: structure_ids,
            color_theme: "bg-teal-600".to_string(),
        });

        // 4. Authority & Governance
        let authority_ids = vec![
            "urn:nostra:book:agent-charter".to_string(),
            "urn:nostra:book:governance-escalation".to_string(),
        ];
        collections.push(BookCollection {
            id: CollectionId::Authority,
            name: "Authority & Governance".to_string(),
            description: "Agent behavior rules, delegation, and escalation frameworks.".to_string(),
            icon: "👑".to_string(),
            book_ids: authority_ids,
            color_theme: "bg-blue-600".to_string(),
        });

        // 5. Knowledge & Security
        let security_ids = vec![
            "urn:nostra:book:knowledge-integrity".to_string(),
            "urn:nostra:book:security-privacy".to_string(),
        ];
        collections.push(BookCollection {
            id: CollectionId::Security,
            name: "Knowledge & Security".to_string(),
            description: "Memory doctrine, privacy principles, and security standards.".to_string(),
            icon: "🔐".to_string(),
            book_ids: security_ids,
            color_theme: "bg-rose-600".to_string(),
        });

        // 6. Compliance & Standards
        let compliance_ids = vec!["book_gdpr".to_string()];
        collections.push(BookCollection {
            id: CollectionId::Compliance,
            name: "Compliance & Standards".to_string(),
            description: "Regulatory standards (GDPR, HIPAA, SOC2) and external compliance."
                .to_string(),
            icon: "📋".to_string(),
            book_ids: compliance_ids,
            color_theme: "bg-slate-600".to_string(),
        });

        // 7. System (Legacy - Now includes Mockup)
        collections.push(BookCollection {
            id: CollectionId::System,
            name: "System".to_string(),
            description: "Internal documentation, legacy library files, and system references."
                .to_string(),
            icon: "⚙️".to_string(),
            book_ids: vec!["legacy_mockup".to_string()],
            color_theme: "bg-gray-600".to_string(),
        });

        // 8. Favorites (Dynamic)
        collections.push(BookCollection {
            id: CollectionId::Favorites,
            name: "Favorites".to_string(),
            description: "Your pinned books for quick access.".to_string(),
            icon: "⭐".to_string(),
            book_ids: vec![], // Populated at runtime
            color_theme: "bg-yellow-600".to_string(),
        });

        // 9. Reading List (Dynamic)
        collections.push(BookCollection {
            id: CollectionId::ReadingList,
            name: "Reading List".to_string(),
            description: "Queue of books to process.".to_string(),
            icon: "🔖".to_string(),
            book_ids: vec![], // Populated at runtime
            color_theme: "bg-orange-600".to_string(),
        });

        collections
    };

    let collections = create_collections(&books);
    let mut selected_collection = use_signal(|| Option::<CollectionId>::None);
    let mut search_query = use_signal(|| String::new());

    let config_modal = if *show_config.read() {
        rsx! {
            div { class: "fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4",
                div { class: "bg-background border border-border rounded-xl shadow-2xl w-full max-w-lg overflow-hidden animate-in fade-in zoom-in duration-200",
                    div { class: "p-6 border-b border-border",
                        h2 { class: "text-xl font-bold", "Library Configuration" }
                        p { class: "text-sm text-muted-foreground", "Configure storage, security, and agent access." }
                    }
                    div { class: "p-6 space-y-6",
                        // Sync Target
                        div { class: "space-y-2",
                            label { class: "text-sm font-medium", "Sync Target" }
                            div { class: "grid grid-cols-2 gap-2",
                                button {
                                    class: format!("px-4 py-2 rounded-md text-sm border transition-colors {}", if config.read().sync_target == SyncTarget::Local { "bg-primary text-primary-foreground border-primary" } else { "bg-muted hover:bg-muted/80 border-transparent" }),
                                    onclick: move |_| config.write().sync_target = SyncTarget::Local,
                                    "Local Only"
                                }
                                button {
                                    class: format!("px-4 py-2 rounded-md text-sm border transition-colors {}", if config.read().sync_target == SyncTarget::Canister { "bg-primary text-primary-foreground border-primary" } else { "bg-muted hover:bg-muted/80 border-transparent" }),
                                    onclick: move |_| config.write().sync_target = SyncTarget::Canister,
                                    "Canister Sync"
                                }
                            }
                        }

                        // Encryption
                        div { class: "space-y-2",
                            label { class: "text-sm font-medium", "Encryption" }
                            select {
                                class: "w-full bg-muted border border-input rounded-md px-3 py-2 text-sm focus:ring-2 focus:ring-ring outline-none",
                                onchange: move |evt| {
                                    let val = evt.value();
                                    if val == "High" { config.write().encryption = EncryptionLevel::High; }
                                    else { config.write().encryption = EncryptionLevel::Standard; }
                                },
                                option { value: "Standard", selected: config.read().encryption == EncryptionLevel::Standard, "Standard (AES-256)" }
                                option { value: "High", selected: config.read().encryption == EncryptionLevel::High, "High (Post-Quantum)" }
                            }
                        }

                        // Toggles
                        div { class: "space-y-4",
                            div { class: "flex items-center justify-between",
                                div {
                                    label { class: "text-sm font-medium block", "Human-in-the-Loop" }
                                    span { class: "text-xs text-muted-foreground", "Require approval for sensitive agent actions" }
                                },
                                button {
                                    class: format!("w-11 h-6 rounded-full transition-colors relative {}", if config.read().human_in_loop { "bg-green-600" } else { "bg-muted" }),
                                    onclick: move |_| { let v = config.read().human_in_loop; config.write().human_in_loop = !v; },
                                    div { class: format!("absolute top-1 w-4 h-4 rounded-full bg-white transition-all shadow-sm {}", if config.read().human_in_loop { "left-6" } else { "left-1" }) }
                                }
                            }

                            div { class: "flex items-center justify-between",
                                div {
                                    label { class: "text-sm font-medium block", "Telemetry" }
                                    span { class: "text-xs text-muted-foreground", "Share anonymous usage data (054 Standard)" }
                                },
                                button {
                                    class: format!("w-11 h-6 rounded-full transition-colors relative {}", if config.read().telemetry_enabled { "bg-blue-600" } else { "bg-muted" }),
                                    onclick: move |_| { let v = config.read().telemetry_enabled; config.write().telemetry_enabled = !v; },
                                    div { class: format!("absolute top-1 w-4 h-4 rounded-full bg-white transition-all shadow-sm {}", if config.read().telemetry_enabled { "left-6" } else { "left-1" }) }
                                }
                            }
                        }
                    }
                    div { class: "p-6 border-t border-border flex justify-end gap-2 bg-muted/20",
                        button {
                            class: "px-4 py-2 text-sm font-medium hover:bg-accent rounded-md",
                            onclick: move |_| show_config.set(false),
                            "Close"
                        }
                    }
                }
            }
        }
    } else {
        rsx! {}
    };

    rsx! {
        div { class: "flex h-full bg-background text-foreground",
            // Sidebar Navigation
            div { class: "w-64 border-r border-border bg-card/30 flex flex-col shrink-0",
                div { class: "p-4 border-b border-border/50",
                    h2 { class: "font-semibold tracking-tight flex items-center gap-2",
                        span { "📚" }
                        "Library"
                    }
                }
                nav { class: "flex-1 p-3 space-y-1 overflow-y-auto",
                    // All Books
                    button {
                        class: format!("w-full text-left px-3 py-2 rounded-md text-sm font-medium transition-colors {}",
                            if selected_collection.read().is_none() && matches!(*current_view.read(), LibraryView::Bookshelf) {
                                "bg-accent text-accent-foreground"
                            } else {
                                "text-muted-foreground hover:bg-accent/50 hover:text-foreground"
                            }
                        ),
                        onclick: move |_| {
                            selected_collection.set(None);
                            current_view.set(LibraryView::Bookshelf);
                        },
                        "🏠 All Books"
                    }

                    div { class: "pt-4 pb-2 px-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider",
                        "Collections"
                    }

                    for collection in &collections {
                        {
                            let is_active = selected_collection.read().as_ref() == Some(&collection.id) && matches!(*current_view.read(), LibraryView::Bookshelf);
                            let col_id = collection.id.clone();
                            rsx! {
                                button {
                                    class: format!("w-full text-left px-3 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-2 {}",
                                        if is_active { "bg-accent text-accent-foreground" } else { "text-muted-foreground hover:bg-accent/50 hover:text-foreground" }
                                    ),
                                    onclick: move |_| {
                                        selected_collection.set(Some(col_id.clone()));
                                        current_view.set(LibraryView::Bookshelf);
                                    },
                                    span { "{collection.icon}" }
                                    span { "{collection.name}" }
                                }
                            }
                        }
                    }
                }
            }

            // Main Content Area
            div { class: "flex-1 flex flex-col overflow-hidden",
                match &*current_view.read() {
                    LibraryView::Bookshelf => {
                         let current_col_id = selected_collection.read();
                         let query = search_query.read().to_lowercase();

                         let display_books = books.iter()
                            .filter(|b| {
                                // 1. Filter by Collection
                                let matches_collection = if let Some(id) = current_col_id.as_ref() {
                                    match id {
                                        CollectionId::Favorites => favorites.read().contains(&b.meta.id),
                                        CollectionId::ReadingList => reading_list.read().contains(&b.meta.id),
                                        _ => {
                                            if let Some(col) = collections.iter().find(|c| &c.id == id) {
                                                col.book_ids.contains(&b.meta.id)
                                            } else {
                                                true
                                            }
                                        }
                                    }
                                } else {
                                    true
                                };

                                // 2. Filter by Search Query
                                let matches_search = if query.is_empty() {
                                    true
                                } else {
                                    b.meta.title.to_lowercase().contains(&query) ||
                                    b.meta.provenance.author_did.to_lowercase().contains(&query)
                                    // Removed description search for now as it's not consistently in meta yet without extra parsing
                                };

                                matches_collection && matches_search
                            })
                            .cloned()
                            .collect::<Vec<_>>();

                        let header_content = if let Some(id) = current_col_id.as_ref() {
                            if let Some(col) = collections.iter().find(|c| &c.id == id) {
                                rsx! {
                                    span { class: "text-3xl", "{col.icon}" }
                                    div {
                                        h1 { class: "text-xl font-bold tracking-tight", "{col.name}" }
                                        p { class: "text-sm text-muted-foreground", "{col.description}" }
                                    }
                                }
                            } else {
                                rsx! {}
                            }
                        } else {
                            rsx! {
                                span { class: "text-3xl", "🏠" }
                                div {
                                    h1 { class: "text-xl font-bold tracking-tight", "All Books" }
                                    p { class: "text-sm text-muted-foreground", "Browse all available knowledge sources." }
                                }
                            }
                        };

                        rsx! {
                            // Header
                            div { class: "h-16 border-b border-border bg-background/50 backdrop-blur flex items-center px-8 justify-between shrink-0",
                                div { class: "flex items-center gap-3",
                                    {header_content}
                                }

                                // Search Input
                                div { class: "flex items-center gap-2",
                                    // Config Button
                                    button {
                                        class: "w-8 h-8 rounded-full bg-muted/50 hover:bg-muted flex items-center justify-center transition-colors text-muted-foreground hover:text-foreground",
                                        onclick: move |_| show_config.set(true),
                                        title: "Library Configuration",
                                        svg { class: "w-4 h-4", fill: "none", stroke: "currentColor", view_box: "0 0 24 24", stroke_width: "2",
                                            path { d: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" }
                                            path { d: "M15 12a3 3 0 11-6 0 3 3 0 016 0z" }
                                        }
                                    }
                                    input {
                                         class: "w-full bg-muted/50 border border-input rounded-full pl-10 pr-4 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:bg-background transition-all",
                                         placeholder: "Search library...",
                                         value: "{search_query}",
                                         oninput: move |evt| search_query.set(evt.value())
                                    }
                                    div { class: "absolute left-3 top-1.5 text-muted-foreground opacity-50",
                                        svg { class: "w-4 h-4", fill: "none", stroke: "currentColor", view_box: "0 0 24 24", stroke_width: "2",
                                            path { d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" }
                                        }
                                    }
                                }
                            }

                            // Books Grid
                            div { class: "flex-1 overflow-y-auto p-8",
                                div { class: "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8",
                                    for book in display_books {
                                        div {
                                            class: "group cursor-pointer flex flex-col gap-4",
                                            onclick: {
                                                let bid = book.meta.id.clone();
                                                move |_| current_view.set(LibraryView::Reader(bid.clone()))
                                            },
                                            // Book Cover Card
                                            div { class: "aspect-[2/3] relative rounded-r-2xl rounded-l-md shadow-lg transition-all duration-300 group-hover:shadow-2xl group-hover:-translate-y-2 group-hover:scale-[1.02] overflow-hidden",
                                                // Spine / Binding effect
                                                div { class: "absolute left-0 top-0 bottom-0 w-3 bg-gradient-to-r from-black/40 to-transparent z-10" }

                                                // Cover Content
                                                div { class: format!("absolute inset-0 {} flex flex-col p-6 text-white text-center justify-between", book.cover_color),
                                                    div { class: "absolute inset-0 bg-black/10" } // Texture overlay

                                                    // Top: Author
                                                    div { class: "relative z-10 text-xs font-medium tracking-widest uppercase opacity-80",
                                                        "{book.meta.provenance.author_did}"
                                                    }

                                                    // Center: Title
                                                    div { class: "relative z-10 font-serif font-bold text-2xl leading-tight",
                                                        "{book.meta.title}"
                                                    }

                                                    // Bottom: Logo/Publisher
                                                    div { class: "relative z-10 opacity-70",
                                                        svg { class: "w-6 h-6 mx-auto", fill: "currentColor", view_box: "0 0 24 24",
                                                            path { d: "M12 2L2 7l10 5 10-5-10-5zm0 9l2.5-1.25L12 8.5l-2.5 1.25L12 11zm0 2.5l-5-2.5-5 2.5L12 22l10-8.5-5-2.5-5 2.5z" }
                                                        }
                                                    }
                                                }
                                            }

                                            // Meta below cover
                                            div { class: "px-1",
                                                h3 { class: "font-semibold text-base mb-1 truncate", "{book.meta.title}" }
                                                p { class: "text-xs text-muted-foreground line-clamp-2", "ID: {book.meta.id}" }

                                                // Tags / Badges
                                                div { class: "flex gap-2 mt-2 items-center justify-between",
                                                     div { class: "flex gap-2",
                                                        if let Some(v) = &book.meta.version {
                                                            span { class: "px-1.5 py-0.5 bg-muted rounded text-[10px] font-mono text-muted-foreground",
                                                                "v{v}"
                                                            }
                                                        }
                                                     }

                                                     // Actions (Fav/List)
                                                     div { class: "flex gap-1",
                                                        // Favorite Toggle
                                                        button {
                                                            class: "p-1 rounded hover:bg-accent/50 transition-colors",
                                                            onclick: {
                                                                let bid = book.meta.id.clone();
                                                                move |e: Event<MouseData>| {
                                                                    e.stop_propagation();
                                                                    let mut favs = favorites.write();
                                                                    if favs.contains(&bid) {
                                                                        favs.remove(&bid);
                                                                    } else {
                                                                        favs.insert(bid.clone());
                                                                    }
                                                                }
                                                            },
                                                            svg {
                                                                class: format!("w-4 h-4 {}", if favorites.read().contains(&book.meta.id) { "text-yellow-500 fill-current" } else { "text-muted-foreground/50" }),
                                                                view_box: "0 0 24 24", stroke: "currentColor", stroke_width: "2", fill: "none",
                                                                path { d: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" }
                                                            }
                                                        }
                                                        // Reading List Toggle
                                                        button {
                                                            class: "p-1 rounded hover:bg-accent/50 transition-colors",
                                                            onclick: {
                                                                let bid = book.meta.id.clone();
                                                                move |e: Event<MouseData>| {
                                                                    e.stop_propagation();
                                                                    let mut list = reading_list.write();
                                                                    if list.contains(&bid) {
                                                                        list.remove(&bid);
                                                                    } else {
                                                                        list.insert(bid.clone());
                                                                    }
                                                                }
                                                            },
                                                            svg {
                                                                class: format!("w-4 h-4 {}", if reading_list.read().contains(&book.meta.id) { "text-orange-500 fill-current" } else { "text-muted-foreground/50" }),
                                                                view_box: "0 0 24 24", stroke: "currentColor", stroke_width: "2", fill: "none",
                                                                path { d: "M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" }
                                                            }
                                                        }
                                                     }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    LibraryView::Reader(id) => rsx! {
                         div { class: "flex flex-col h-full",
                            // Reader Header
                            div { class: "h-14 border-b border-border bg-card/50 flex items-center justify-between px-4 shrink-0",
                                div { class: "flex items-center gap-4",
                                    button {
                                        class: "flex items-center gap-1 text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-muted/50 px-3 py-1.5 rounded-md transition-colors",
                                        onclick: move |_| current_view.set(LibraryView::Bookshelf),
                                        span { "←" }
                                        "Back to Library"
                                    }
                                    div { class: "h-4 w-px bg-border mx-2" }
                                    h2 { class: "font-semibold text-sm",
                                        if let Some(book) = books.iter().find(|b| &b.meta.id == id) {
                                            "{book.meta.title}"
                                        } else {
                                            "Book"
                                        }
                                    }
                                }

                                // Reader Controls
                                div { class: "flex items-center gap-4",
                                    // Cortex Mode Toggle
                                    div { class: "flex items-center space-x-2 text-xs font-medium",
                                        label { class: if *show_cortex.read() { "text-purple-400" } else { "text-muted-foreground" }, "Cortex Mode" }
                                        button {
                                            class: format!("w-8 h-4 rounded-full transition-colors relative {}", if *show_cortex.read() { "bg-purple-600" } else { "bg-muted" }),
                                            onclick: move |_| show_cortex.toggle(),
                                            div { class: format!("absolute top-0.5 w-3 h-3 rounded-full bg-white transition-all shadow-sm {}", if *show_cortex.read() { "left-4.5" } else { "left-0.5" }) }
                                        }
                                    }

                                     // Raw Text Toggle
                                    div { class: "flex items-center space-x-2 text-xs font-medium",
                                        label { class: if *show_raw.read() { "text-primary" } else { "text-muted-foreground" }, "Raw Text" }
                                        button {
                                            class: format!("w-8 h-4 rounded-full transition-colors relative {}", if *show_raw.read() { "bg-primary" } else { "bg-muted" }),
                                            onclick: move |_| show_raw.toggle(),
                                            div { class: format!("absolute top-0.5 w-3 h-3 rounded-full bg-white transition-all shadow-sm {}", if *show_raw.read() { "left-4.5" } else { "left-0.5" }) }
                                        }
                                    }
                                }
                            }

                            // Reader Body (reusing logic but cleaned up wrapper)
                            div { class: "flex-1 overflow-hidden relative",
                                if let Some(book) = books.iter().find(|b| &b.meta.id == id) {
                                     div { class: "h-full flex flex-col md:flex-row max-w-7xl mx-auto bg-background shadow-xl overflow-hidden border-x",
                                        // TOC
                                        div { class: "w-64 border-r bg-muted/10 p-4 hidden lg:block overflow-y-auto shrink-0",
                                            h3 { class: "font-bold text-xs uppercase tracking-widest text-muted-foreground mb-4", "Table of Contents" }
                                            ul { class: "space-y-1",
                                                for content in book.content.iter() {
                                                    li { class: "text-sm py-2 px-3 rounded-md hover:bg-accent hover:text-accent-foreground cursor-pointer transition-colors text-muted-foreground hover:translate-x-1 duration-200",
                                                        "{content.title.clone().unwrap_or_default()}"
                                                    }
                                                }
                                            }
                                        }

                                        // Content
                                        div { class: "flex-1 overflow-y-auto bg-background relative",
                                            // Lab Banner
                                            div { class: "sticky top-0 z-10 bg-blue-500/10 text-blue-600 dark:text-blue-400 px-4 py-2 text-xs font-medium flex justify-between backdrop-blur-md border-b border-blue-500/20",
                                                span { "🧪 Lab Experiment: Graph-based Knowledge Node" }
                                                span { "v{book.meta.version.clone().unwrap_or_default()}" }
                                            }

                                            div { class: "p-8 md:p-12 lg:p-16 max-w-3xl mx-auto",
                                                // Book Header
                                                div { class: "text-center pb-12 mb-12 border-b border-border/50",
                                                    h1 { class: "text-4xl md:text-5xl font-serif font-bold mb-4 tracking-tight text-foreground", "{book.meta.title}" }
                                                    p { class: "text-lg text-muted-foreground font-medium", "by {book.meta.provenance.author_did}" }
                                                    p { class: "text-xs text-muted-foreground mt-4 uppercase tracking-widest", "Published {book.meta.provenance.created_at}" }
                                                }

                                                // Book Content Loop
                                                for content in book.content.iter() {
                                                    div { class: "mb-16",
                                                        if let Some(t) = &content.title {
                                                            h2 { class: "text-2xl font-serif font-bold mb-6 text-foreground", "{t}" }
                                                        }
                                                        for block in content.blocks.iter() {
                                                            match block {
                                                                Block::Heading { level, content } => rsx! {
                                                                    h3 { class: "text-xl font-bold mt-4 mb-2", "{content}" }
                                                                },
                                                                Block::Paragraph { content } => rsx! {
                                                                     div { class: "prose dark:prose-invert prose-lg max-w-none text-muted-foreground leading-relaxed mb-4",
                                                                        match content {
                                                                            ContentValue::String(s) => rsx! { "{s}" },
                                                                            ContentValue::Rich(spans) => rsx! {
                                                                                for span in spans {
                                                                                    match span {
                                                                                        RichTextSpan::Text { value } => rsx! { "{value}" },
                                                                                        RichTextSpan::Bold { value } => rsx! { strong { "{value}" } },
                                                                                        RichTextSpan::Italic { value } => rsx! { em { "{value}" } },
                                                                                    }
                                                                                }
                                                                            }
                                                                        }
                                                                     }
                                                                },
                                                                Block::LegacyHtml { content } => rsx! {
                                                                    if *show_raw.read() {
                                                                        pre { class: "bg-muted p-4 rounded-lg overflow-x-auto text-xs font-mono border", "{content}" }
                                                                    } else {
                                                                        div { class: "prose dark:prose-invert prose-lg max-w-none text-muted-foreground leading-relaxed",
                                                                            dangerous_inner_html: "{content}"
                                                                        }
                                                                    }
                                                                },
                                                                _ => rsx! { div { "Block type not rendered" } }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        // Cortex Console
                                        if *show_cortex.read() {
                                            div { class: "w-80 border-l border-border bg-black text-green-400 p-4 overflow-y-auto font-mono text-xs shadow-2xl shrink-0",
                                                div { class: "flex items-center gap-2 mb-4 pb-2 border-b border-green-900/50",
                                                    div { class: "w-2 h-2 bg-green-500 rounded-full animate-pulse" }
                                                    span { class: "font-bold tracking-widest", "CORTEX_AGENT: ACTIVE" }
                                                }
                                                div { class: "space-y-4 font-screen",
                                                    div { class: "opacity-60", "$ initiating knowledge_graph_scan..." }
                                                    div { class: "opacity-60", "$ analyzing normative_references..." }
                                                    div { class: "p-3 bg-green-900/10 rounded border border-green-900/30",
                                                        span { class: "text-white font-bold block mb-1", "Detected: Governance Node" }
                                                        "Validated conformity with Nostra Labs Constitution v0.1"
                                                    }
                                                    // Dynamic content based on book
                                                    if book.meta.id == "book_gdpr" {
                                                        div { class: "p-3 bg-red-900/20 rounded border border-red-900/30",
                                                            span { class: "text-red-400 font-bold block mb-1", "alert: PolicyBlock(Erase)" }
                                                            "Simulating immutable erasure constraints..."
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                     }
                                }
                            }
                        }
                    }
                }
            }
            // Config Modal
            if *show_config.read() {
                div { class: "fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4",
                    div { class: "bg-background border border-border rounded-xl shadow-2xl w-full max-w-lg overflow-hidden animate-in fade-in zoom-in duration-200",
                        div { class: "p-6 border-b border-border",
                            h2 { class: "text-xl font-bold", "Library Configuration" }
                            p { class: "text-sm text-muted-foreground", "Configure storage, security, and agent access." }
                        }
                        div { class: "p-6 space-y-6",
                            // Sync Target
                            div { class: "space-y-2",
                                label { class: "text-sm font-medium", "Sync Target" }
                                div { class: "grid grid-cols-2 gap-2",
                                    button {
                                        class: format!("px-4 py-2 rounded-md text-sm border transition-colors {}", if config.read().sync_target == SyncTarget::Local { "bg-primary text-primary-foreground border-primary" } else { "bg-muted hover:bg-muted/80 border-transparent" }),
                                        onclick: move |_| config.write().sync_target = SyncTarget::Local,
                                        "Local Only"
                                    }
                                    button {
                                        class: format!("px-4 py-2 rounded-md text-sm border transition-colors {}", if config.read().sync_target == SyncTarget::Canister { "bg-primary text-primary-foreground border-primary" } else { "bg-muted hover:bg-muted/80 border-transparent" }),
                                        onclick: move |_| config.write().sync_target = SyncTarget::Canister,
                                        "Canister Sync"
                                    }
                                }
                            }

                            // Encryption
                            div { class: "space-y-2",
                                label { class: "text-sm font-medium", "Encryption" }
                                select {
                                    class: "w-full bg-muted border border-input rounded-md px-3 py-2 text-sm focus:ring-2 focus:ring-ring outline-none",
                                    onchange: move |evt| {
                                        let val = evt.value();
                                        if val == "High" { config.write().encryption = EncryptionLevel::High; }
                                        else { config.write().encryption = EncryptionLevel::Standard; }
                                    },
                                    option { value: "Standard", selected: config.read().encryption == EncryptionLevel::Standard, "Standard (AES-256)" }
                                    option { value: "High", selected: config.read().encryption == EncryptionLevel::High, "High (Post-Quantum)" }
                                }
                            }

                            // Toggles
                            div { class: "space-y-4",
                                div { class: "flex items-center justify-between",
                                    div {
                                        label { class: "text-sm font-medium block", "Human-in-the-Loop" }
                                        span { class: "text-xs text-muted-foreground", "Require approval for sensitive agent actions" }
                                    },
                                    button {
                                        class: format!("w-11 h-6 rounded-full transition-colors relative {}", if config.read().human_in_loop { "bg-green-600" } else { "bg-muted" }),
                                        onclick: move |_| { let v = config.read().human_in_loop; config.write().human_in_loop = !v; },
                                        div { class: format!("absolute top-1 w-4 h-4 rounded-full bg-white transition-all shadow-sm {}", if config.read().human_in_loop { "left-6" } else { "left-1" }) }
                                    }
                                }

                                div { class: "flex items-center justify-between",
                                    div {
                                        label { class: "text-sm font-medium block", "Telemetry" }
                                        span { class: "text-xs text-muted-foreground", "Share anonymous usage data (054 Standard)" }
                                    },
                                    button {
                                        class: format!("w-11 h-6 rounded-full transition-colors relative {}", if config.read().telemetry_enabled { "bg-blue-600" } else { "bg-muted" }),
                                        onclick: move |_| { let v = config.read().telemetry_enabled; config.write().telemetry_enabled = !v; },
                                        div { class: format!("absolute top-1 w-4 h-4 rounded-full bg-white transition-all shadow-sm {}", if config.read().telemetry_enabled { "left-6" } else { "left-1" }) }
                                    }
                                }
                            }
                        }
                        div { class: "p-6 border-t border-border flex justify-end gap-2 bg-muted/20",
                            button {
                                class: "px-4 py-2 text-sm font-medium hover:bg-accent rounded-md",
                                onclick: move |_| show_config.set(false),
                                "Close"
                            }
                        }
                    }
                }
            }
        }
    }
}
