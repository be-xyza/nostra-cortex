UPSERT {
    CONCEPT ?infra_type {
        {type: "$ConceptType", name: "Infrastructure"}
        SET ATTRIBUTES {
            description: "Physical or virtual infrastructure component (Subnet, Node, DataCenter)",
            archetype: "concept",
            version: "1.0.0"
        }
        SET PROPOSITIONS {
            ("belongs_to_domain", {type: "Domain", name: "ICPKnowledge"})
        }
    }
}
WITH METADATA { source: "icp-core", author: "$system" }
