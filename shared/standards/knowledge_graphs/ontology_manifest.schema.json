{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.dev/schemas/knowledge_graphs/ontology_manifest.schema.json",
  "title": "Nostra Core Ontology Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ontology_id",
    "title",
    "version",
    "description",
    "classes",
    "relations",
    "properties",
    "extension_rules",
    "compatibility"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "ontology_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "classes": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/Term"
      }
    },
    "relations": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/Relation"
      }
    },
    "properties": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/Property"
      }
    },
    "extension_rules": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "breaking_change_policy",
        "space_extension_policy"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["additive"]
        },
        "breaking_change_policy": {
          "type": "string",
          "minLength": 1
        },
        "space_extension_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "Term": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "extends": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "Relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "source",
        "target"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "inverse": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "Property": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "applies_to",
        "value_type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "value_type": {
          "type": "string",
          "minLength": 1
        },
        "cardinality": {
          "type": "string",
          "enum": ["single", "optional", "repeatable"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
