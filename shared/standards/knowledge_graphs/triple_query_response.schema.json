{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.dev/schemas/knowledge_graphs/triple_query_response.schema.json",
  "title": "Nostra Triple Query Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "query_id",
    "ordering_strategy",
    "scope",
    "result_count",
    "triples"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "query_id": {
      "type": "string",
      "minLength": 1
    },
    "ordering_strategy": {
      "type": "string",
      "enum": ["canonical"]
    },
    "scope": {
      "$ref": "#/$defs/QueryScope"
    },
    "result_count": {
      "type": "integer",
      "minimum": 0
    },
    "triples": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TripleMatch"
      }
    }
  },
  "$defs": {
    "QueryScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "named_graph_scope"
      ],
      "properties": {
        "named_graph_scope": {
          "type": "string",
          "enum": ["system", "actor", "agent", "any"]
        },
        "scope_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "TripleMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "subject",
        "predicate",
        "object",
        "graph_scope",
        "provenance_scope",
        "source_ref"
      ],
      "properties": {
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "predicate": {
          "type": "string",
          "minLength": 1
        },
        "object": {
          "type": "string",
          "minLength": 1
        },
        "graph_scope": {
          "type": "string",
          "enum": ["system", "actor", "agent"]
        },
        "provenance_scope": {
          "type": "string",
          "enum": ["system", "actor", "agent"]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
