  "title": "Cortex Terminal Document v1",
  "type": "object",
  "required": ["type"],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["Container", "Box", "Text", "Spacer", "SelectList"]
