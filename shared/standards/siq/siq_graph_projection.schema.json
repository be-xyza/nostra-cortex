{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nostra.dev/schemas/siq/siq_graph_projection.schema.json",
  "title": "System Integrity + Quality Graph Projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "run_id",
    "graph_fingerprint",
    "integrity_set",
    "edge_types",
    "entities",
    "edges"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "graph_fingerprint": {
      "type": "string",
      "minLength": 8
    },
    "integrity_set": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{3}$"
      }
    },
    "edge_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "contribution_has_rule",
          "rule_has_run",
          "run_emits_violation",
          "violation_backed_by_evidence",
          "contribution_has_waiver"
        ]
      }
    },
    "entities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contributions",
        "rules",
        "gate_runs",
        "violations",
        "evidence",
        "waivers"
      ],
      "properties": {
        "contributions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Node"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Node"
          }
        },
        "gate_runs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Node"
          }
        },
        "violations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Node"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Node"
          }
        },
        "waivers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Node"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Edge"
      }
    }
  },
  "$defs": {
    "Node": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "type",
        "from",
        "to"
      ],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "contribution_has_rule",
            "rule_has_run",
            "run_emits_violation",
            "violation_backed_by_evidence",
            "contribution_has_waiver"
          ]
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
