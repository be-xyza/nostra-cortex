{
  "schema_version": "1.0.0",
  "ontology_id": "nostra.space.invalid_provenance_extension.v1",
  "title": "Invalid Provenance Extension Ontology",
  "version": "1.0.0",
  "description": "Negative fixture that attempts to extend the closed ProvenanceScope core set.",
  "classes": [
    {
      "id": "Space",
      "description": "Sovereign container for policies, contributions, and knowledge bundles."
    },
    {
      "id": "Contribution",
      "description": "Governed unit of knowledge, work, or evidence that can be linked and versioned."
    },
    {
      "id": "Relation",
      "description": "Typed link between two governed graph subjects."
    },
    {
      "id": "Capability",
      "description": "A declared ability or feature exposed by a Space or contribution surface."
    },
    {
      "id": "ProvenanceScope",
      "description": "Named graph scope used to partition evidence and traversal."
    },
    {
      "id": "bad:TenantScope",
      "description": "Invalid extension of a closed core provenance scope.",
      "extends": ["ProvenanceScope"]
    }
  ],
  "relations": [
    {
