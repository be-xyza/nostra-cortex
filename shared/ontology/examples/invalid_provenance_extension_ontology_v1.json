      "description": "Human-readable label.",
      "applies_to": ["Space", "Contribution", "Capability", "Relation"],
      "value_type": "Text",
      "cardinality": "single"
    },
    {
      "id": "description",
      "description": "Short explanatory text.",
      "applies_to": ["Space", "Contribution", "Capability", "Relation"],
      "value_type": "Text",
      "cardinality": "optional"
    },
    {
      "id": "resource_ref",
      "description": "Canonical portable identifier for a graph subject or relation.",
      "applies_to": ["Space", "Contribution", "Capability", "Relation"],
      "value_type": "ResourceRef",
      "cardinality": "single"
    },
    {
