{
  "schema_version": "CortexWebHeapBlockCapabilityInventoryV1",
  "snapshot_id": "system:ux:heap-block-capability-inventory",
  "inventory_id": "cortex-web-heap-block-capability-observability",
  "authority_mode": "recommendation_only",
  "captured_from": {
    "local_url": "http://127.0.0.1:4173/explore",
    "captured_at": "2026-04-29",
    "viewport": "1440x1000",
    "notes": [
      "Inventory records Heap and block capability observability only.",
      "Route, shell, settings, and nav classification are covered by CortexWebShellSurfaceInventoryV1."
    ]
  },
  "scope_boundaries": {
    "includes": [
      "heap_view_modes",
      "heap_action_zones",
      "block_card_actions",
      "block_detail_tabs",
      "create_panel_modes",
      "upload_extraction_status_surfaces",
      "steward_gate_visibility",
      "relation_editor_visibility",
      "chat_overlay_visibility",
      "comment_sidebar_visibility"
    ],
    "excludes": [
      "route_surface_classification",
      "settings_information_architecture",
      "runtime_mutation_authority",
      "provider_topology_visibility",
      "external_design_system_imports"
    ]
  },
  "capability_classes": [
    "read_projection",
    "local_ui_state",
    "runtime_read",
    "runtime_write",
    "steward_gated_write",
    "destructive_write",
    "download",
    "placeholder_or_disabled",
    "overlay_interaction"
  ],
  "heap_views": [
    {
      "id": "Explore",
      "query_param": "all",
      "class": "read_projection",
      "status": "functional",
      "source": "heapViewModel"
    },
    {
      "id": "Inbox",
      "query_param": "inbox",
      "class": "read_projection",
      "status": "functional",
      "source": "heapViewModel",
      "notes": "Includes mentions, urgent blocks, review work, and blocks lacking relation context."
    },
    {
      "id": "Drafts",
      "query_param": "drafts",
      "class": "read_projection",
      "status": "functional_empty_allowed",
      "source": "heapViewModel"
    },
    {
      "id": "Tasks",
      "query_param": "tasks",
      "class": "read_projection",
      "status": "functional_empty_allowed",
      "source": "heapViewModel"
    },
    {
      "id": "Proposals",
      "query_param": "proposals",
      "class": "read_projection",
      "status": "functional_empty_allowed",
      "source": "heapViewModel"
    },
    {
      "id": "Activity",
      "query_param": "activity",
      "class": "read_projection",
      "status": "functional",
      "source": "heapViewModel"
    },
    {
      "id": "Pinned",
      "query_param": "pinned",
      "class": "read_projection",
      "status": "functional_empty_allowed",
      "source": "heapViewModel"
    },
    {
      "id": "Archive",
      "query_param": "archive",
      "class": "read_projection",
      "status": "functional_empty_allowed",
      "source": "heapViewModel"
    }
  ],
  "action_zones": [
    {
      "zone": "heap_page_bar",
      "source": "useHeapActionPlan",
      "fallback_source": "heapActionPlan",
      "actions": ["create"]
    },
    {
      "zone": "heap_selection_bar",
      "source": "useHeapActionPlan",
      "fallback_source": "heapActionPlan",
      "actions": ["regenerate", "refine_selection", "export", "history", "publish", "synthesize", "pin", "delete"]
    },
    {
      "zone": "heap_card_menu",
      "source": "useHeapActionPlan",
      "fallback_source": "heapActionPlan",
      "actions": ["discussion", "history", "pin", "delete"]
    },
    {
      "zone": "heap_detail_header",
      "source": "useHeapActionPlan",
      "fallback_source": "heapActionPlan",
      "actions": ["discussion", "relation_edit", "regenerate"]
    },
    {
      "zone": "heap_detail_footer",
      "source": "useHeapActionPlan",
      "fallback_source": "heapActionPlan",
      "actions": ["discussion", "relation_edit", "regenerate"]
    }
  ],
  "actions": [
    {
      "id": "create",
      "label": "Create",
      "class": "runtime_write",
      "status": "functional_with_modes",
      "zones": ["heap_page_bar"],
      "required_observability": ["mode", "space_id", "actor_role", "payload_type", "status_message"]
    },
    {
      "id": "regenerate",
      "label": "Regenerate",
      "class": "placeholder_or_disabled",
      "status": "handler_only",
      "zones": ["heap_selection_bar", "heap_detail_header", "heap_detail_footer"],
      "required_observability": ["selected_artifact_ids", "action_plan_source", "disabled_reason"]
    },
    {
      "id": "refine_selection",
      "label": "Refine Selection",
      "class": "runtime_read",
      "status": "functional_context_bundle",
      "zones": ["heap_selection_bar"],
      "required_observability": ["selected_artifact_ids", "context_bundle_status", "action_plan_source"]
    },
    {
      "id": "export",
      "label": "Export",
      "class": "download",
      "status": "functional",
      "zones": ["heap_selection_bar"],
      "required_observability": ["selected_artifact_ids", "format", "download_status"]
    },
    {
      "id": "history",
      "label": "History",
      "class": "runtime_read",
      "status": "functional",
      "zones": ["heap_selection_bar", "heap_card_menu"],
      "required_observability": ["artifact_id", "history_fetch_status"]
    },
    {
      "id": "publish",
      "label": "Publish",
      "class": "steward_gated_write",
      "status": "functional_with_steward_gate",
      "zones": ["heap_selection_bar"],
      "required_observability": ["artifact_id", "gate_status", "steward_identity", "publish_status"]
    },
    {
      "id": "synthesize",
      "label": "Synthesize",
      "class": "runtime_write",
      "status": "functional_selection_summary",
      "zones": ["heap_selection_bar"],
      "required_observability": ["selected_artifact_ids", "minimum_selection", "emitted_artifact_id"]
    },
    {
      "id": "pin",
      "label": "Pin",
      "class": "runtime_write",
      "status": "functional",
      "zones": ["heap_selection_bar", "heap_card_menu"],
      "required_observability": ["artifact_id", "pin_status"]
    },
    {
      "id": "delete",
      "label": "Delete",
      "class": "destructive_write",
      "status": "functional_requires_confirmation",
      "zones": ["heap_selection_bar", "heap_card_menu"],
      "required_observability": ["artifact_id", "confirmation_state", "delete_status"],
      "confirmation_contract": {
        "required": true,
        "style": "danger",
        "fallback_enforced": true
      }
    },
    {
      "id": "discussion",
      "label": "Discussion",
      "class": "local_ui_state",
      "status": "functional_local_sidebar",
      "zones": ["heap_card_menu", "heap_detail_header", "heap_detail_footer"],
      "required_observability": ["artifact_id", "comment_count", "sidebar_open"]
    },
    {
      "id": "relation_edit",
      "label": "Relations",
      "class": "runtime_write",
      "status": "functional_relation_editor_toggle",
      "zones": ["heap_detail_header", "heap_detail_footer"],
      "required_observability": ["artifact_id", "relation_editor_open", "relation_dirty_state"]
    }
  ],
